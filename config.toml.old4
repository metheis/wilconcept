baseURL = "https://wilab.ml"
title = "simplog"
description = ""
author = "michimani"
copyright = "MIT License"
paginate = 3
languageCode = "en"
DefaultContentLanguage = "en"
enableInlineShortcodes = true
ignoreErrors = ["error-remote-getjson"]
googleAnalytics = ""
disqusShortname = ""

theme = "simplog"

